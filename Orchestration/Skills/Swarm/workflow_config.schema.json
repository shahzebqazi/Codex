{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dotai.dev/schemas/workflow_config.json",
  "title": "WorkflowConfig",
  "description": "Configuration for a workflow-based agent swarm (extends swarm config with workflow mode and stage-level fields)",
  "type": "object",
  "required": ["version", "mode"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "mode": {
      "type": "string",
      "enum": ["single_prd", "all_prds_parallel", "workflow"],
      "description": "Execution mode: one PRD, all PRDs in parallel, or workflow-driven"
    },
    "prd_ref": {
      "type": "string",
      "description": "For single_prd: PRD id or path"
    },
    "prd_list": {
      "type": "array",
      "items": { "type": "string" },
      "description": "For all_prds_parallel: list of PRD ids or paths"
    },
    "workflow_ref": {
      "type": "string",
      "description": "For workflow mode: workflow id or path (e.g. consolidate-prds, Workflows/CONSOLIDATE_PRDS.md)"
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/definitions/Task" },
      "description": "Task graph; when mode is workflow, tasks may include stage fields (role, context_budget, etc.)"
    },
    "stages": {
      "type": "array",
      "items": { "$ref": "#/definitions/Stage" },
      "description": "For workflow mode: pipeline stages with role, budgets, inputs/outputs. Alternative to tasks when emitting workflow config."
    },
    "models": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/ModelSpec" },
      "description": "Optional map of model_key to endpoint/role"
    },
    "subagent_policy": {
      "type": "string",
      "enum": ["none", "independent_only", "per_prd", "full"],
      "default": "independent_only",
      "description": "When to use subagents"
    }
  },
  "definitions": {
    "Task": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "prd_ref": { "type": "string" },
        "stage_id": { "type": "string", "description": "For workflow: stage id from workflow definition" },
        "owner": { "type": "string" },
        "role": { "type": "string", "description": "Agent role name (e.g. Coordinator, XP Engineer Reviewer)" },
        "model_key": { "type": "string" },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "acceptance_criteria": { "type": "string" },
        "subagent_type": {
          "type": "string",
          "enum": ["generalPurpose", "explore", "shell", "code-reviewer", "ci-watcher", "other"]
        },
        "task_type": {
          "type": "string",
          "enum": ["planning", "code", "review", "refactor", "docs", "research"]
        },
        "context_budget": { "type": "integer", "description": "Input token budget for this task/stage" },
        "output_budget": { "type": "integer", "description": "Output token budget" },
        "turns": { "type": ["string", "integer"], "description": "Estimated conversation turns" },
        "inputs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What this stage reads"
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What this stage produces"
        }
      }
    },
    "Stage": {
      "type": "object",
      "required": ["stage_id", "role", "task_type"],
      "properties": {
        "stage_id": { "type": "string" },
        "role": { "type": "string" },
        "task_type": {
          "type": "string",
          "enum": ["planning", "code", "review", "refactor", "docs", "research"]
        },
        "model_key": { "type": "string" },
        "context_budget": { "type": "integer" },
        "output_budget": { "type": "integer" },
        "turns": { "type": ["string", "integer"] },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "acceptance_criteria": { "type": "string" },
        "subagent_type": {
          "type": "string",
          "enum": ["generalPurpose", "explore", "shell", "code-reviewer", "ci-watcher", "other"]
        }
      }
    },
    "ModelSpec": {
      "type": "object",
      "properties": {
        "endpoint": { "type": "string" },
        "provider": { "type": "string" },
        "role": { "type": "string" }
      }
    }
  }
}
